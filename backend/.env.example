# =============================================================================
# Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# The application will REFUSE TO START without JWT_SECRET and GOOGLE_CLIENT_ID.

# -----------------------------------------------------------------------------
# MANDATORY — app will exit(1) if missing
# -----------------------------------------------------------------------------

# A strong random secret for signing JWT tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=

# Your Google OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# Cookie Security — explicit per-attribute control (no single PRODUCTION flag)
# -----------------------------------------------------------------------------

# Set to "true" in production (requires HTTPS). Blocks cookies over plain HTTP.
COOKIE_SECURE=false

# "lax" for same-origin, "none" for cross-origin (requires COOKIE_SECURE=true)
COOKIE_SAMESITE=lax

# Set to your production domain (e.g. ".bitsathy.ac.in") or leave blank for dev.
COOKIE_DOMAIN=

# -----------------------------------------------------------------------------
# CORS — comma-separated origins, NO wildcards
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# -----------------------------------------------------------------------------
# Logging (optional — sensible defaults built in)
# -----------------------------------------------------------------------------
# LOG_DIR=./logs
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=10
# LOG_RETENTION_DAYS=90
